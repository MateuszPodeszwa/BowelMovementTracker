@using BowelMovementTracker.Data.Enums
@using Microsoft.IdentityModel.Tokens
@model AnalyticsViewModel

@{
  var now = DateTime.UtcNow;
  var daysInCurrentMonth = DateTime.DaysInMonth(now.Year, now.Month);
  var firstDayOfMonth = new DateTime(now.Year, now.Month, 1, 0, 0, 0, DateTimeKind.Utc);
  var lastDayOfMonth = new DateTime(now.Year, now.Month, daysInCurrentMonth, 23, 59, 59, 999, DateTimeKind.Utc);
  var startDayOffset = (int)firstDayOfMonth.DayOfWeek;

  Model.ApplyDashboardDateFilter(firstDayOfMonth, lastDayOfMonth);
  var logs = Model.FilteredDashboardLogs;
}

<style>
  .calendar-wrapper {
    background-color: var(--bs-body-bg);
    color: var(--bs-body-color);
  }

  .global-close-radio {
    display: none;
  }

  /* 1. Base Grid */
  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0.5rem;
  }

  @@media (min-width: 768px) {
    .calendar-grid {
      gap: 1rem;
    }
  }

  .day-wrapper {
    position: relative;
    display: flex;
    min-height: 110px;
    border-radius: var(--bs-border-radius-lg);
  }

  @@media (min-width: 768px) {
    .day-wrapper {
      min-height: 130px;
    }
  }

  .day-wrapper.empty {
    border: 1px dashed var(--bs-border-color);
    background-color: transparent;
    opacity: 0.5;
  }

  /* Raise the z-index of ONLY the active wrapper */
  .day-wrapper:has(.day-toggle:checked) {
    z-index: 50;
  }

  /* 2. The Static Front Card */
  .day-toggle {
    display: none;
  }

  .day-front {
    display: flex;
    flex-direction: column;
    width: 100%;
    background-color: var(--bs-tertiary-bg);
    border: 1px solid var(--bs-border-color);
    border-radius: var(--bs-border-radius-lg);
    cursor: pointer;
    transition: all 0.2s ease;
    overflow: hidden;
  }

  .day-front:hover {
    border-color: var(--bs-primary);
    box-shadow: var(--bs-box-shadow-sm);
  }

  /* 3. The New Popout Overlay (Scaled down to 4x3 Grid Size) */
  .day-popout {
    position: absolute;
    top: -2px;
    left: -2px;
    /* Width: 4 columns (400%) + 3 gaps (1.5rem) + 4px borders */
    width: calc(400% + 1.5rem + 4px);
    /* Height: 3 rows (300%) + 2 gaps (1rem) + 4px borders */
    height: calc(300% + 1rem + 4px);
    background-color: var(--bs-body-bg);
    border: 2px solid var(--bs-primary);
    border-radius: var(--bs-border-radius-lg);
    box-shadow: var(--bs-box-shadow-lg);
    display: flex;
    opacity: 0;
    visibility: hidden;
    transform: scale(0.95);
    transform-origin: left top;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 100;
  }

  @@media (min-width: 768px) {
    .day-popout {
      /* Desktop gap is 1rem */
      width: calc(400% + 3rem + 4px);
      height: calc(300% + 2rem + 4px);
    }
  }

  /* --- SMART EDGE DETECTION TO KEEP IT INSIDE THE CALENDAR --- */

  /* Right-Edge Case: Thu, Fri, Sat pop out to the left */
  .day-wrapper:nth-of-type(7n) .day-popout,
  .day-wrapper:nth-of-type(7n-1) .day-popout,
  .day-wrapper:nth-of-type(7n-2) .day-popout {
    left: auto;
    right: -2px;
    transform-origin: right top;
    flex-direction: row-reverse;
  }

  /* Bottom-Edge Case: Last 14 elements (last 2 rows) expand UPWARDS */
  .day-wrapper:nth-last-of-type(-n+14) .day-popout {
    top: auto;
    bottom: -2px;
    transform-origin: left bottom;
  }

  /* Combined Bottom & Right Edge Case */
  .day-wrapper:nth-last-of-type(-n+14):nth-of-type(7n) .day-popout,
  .day-wrapper:nth-last-of-type(-n+14):nth-of-type(7n-1) .day-popout,
  .day-wrapper:nth-last-of-type(-n+14):nth-of-type(7n-2) .day-popout {
    transform-origin: right bottom;
  }

  /* ----------------------------------------------------------- */

  /* Trigger Popout */
  .day-toggle:checked ~ .day-popout {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
  }

  /* Popout Internals */
  .popout-half {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* The left 'cover' is now 1 column out of 4 (25%) */
  .popout-left {
    width: 25%;
    border-right: 1px solid var(--bs-border-color-translucent);
  }

  /* The history panel gets the remaining 3 columns (75%) */
  .popout-right {
    width: 75%;
  }

  /* Reverse inner border for right-anchored popouts */
  .day-wrapper:nth-of-type(7n) .popout-left,
  .day-wrapper:nth-of-type(7n-1) .popout-left,
  .day-wrapper:nth-of-type(7n-2) .popout-left {
    border-right: none;
    border-left: 1px solid var(--bs-border-color-translucent);
  }

  /* Invisible overlay to close the calendar when clicking the left side of the popout */
  .close-trigger {
    position: absolute;
    inset: 0;
    z-index: 10;
    cursor: pointer;
    margin: 0;
  }

  /* Event Dots & Pure CSS Tooltips */
  .event-dots-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
  }

  .event-dot {
    font-size: 0.7rem;
    position: relative;
    cursor: help;
  }

  .event-dot::after {
    content: attr(data-category);
    position: absolute;
    bottom: 150%;
    left: 50%;
    transform: translateX(-50%) scale(0.8);
    background-color: var(--bs-emphasis-color);
    color: var(--bs-body-bg);
    padding: 0.25rem 0.6rem;
    border-radius: var(--bs-border-radius-sm);
    font-size: 0.75rem;
    font-weight: 500;
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    white-space: nowrap;
    z-index: 60;
    pointer-events: none;
  }

  .event-dot:hover::after {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) scale(1);
  }
</style>

<div class="calendar-wrapper container-fluid p-3 p-md-4 h-100 d-flex flex-column rounded-4 border shadow-sm">

  <header class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <button class="btn btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center p-2"
            style="width: 40px; height: 40px;">
      <i class="bi bi-chevron-left"></i>
    </button>
    <div class="text-center">
      <h2 class="mb-0 fw-bold tracking-tight">@now.ToString("MMMM yyyy")</h2>
      <span class="text-muted small">Event Schedule</span>
    </div>
    <button class="btn btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center p-2"
            style="width: 40px; height: 40px;">
      <i class="bi bi-chevron-right"></i>
    </button>
  </header>

  <div class="calendar-grid mb-2 text-center fw-semibold text-secondary text-uppercase"
       style="font-size: 0.8rem; letter-spacing: 1px;">
    <div>Sun</div>
    <div>Mon</div>
    <div>Tue</div>
    <div>Wed</div>
    <div>Thu</div>
    <div>Fri</div>
    <div>Sat</div>
  </div>

  <div class="calendar-grid flex-grow-1">

    <input type="radio" name="calendar-day" id="close-calendar" class="global-close-radio" checked>

    @for (var i = 0; i < startDayOffset; i++)
    {
      <div class="day-wrapper empty"></div>
    }

    @for (var index = 1; index <= daysInCurrentMonth; index++)
    {
      var currentLog = logs.Where(l => l.DateTime?.Day == index).ToList();
      var isToday = (index == now.Day);

      <div class="day-wrapper">
        <input type="radio" name="calendar-day" id="day-@index" class="day-toggle">

        <label class="day-front p-2 p-md-3 m-0 @(isToday ? "border-primary bg-primary-subtle" : "")" for="day-@index">
          <span class="fs-5 fw-bold @(isToday ? "text-primary" : "")">@(index.ToString("00"))</span>

          <div class="event-dots-container">
            @if (currentLog.Any())
            {
              <i class="bi bi-square-fill text-success event-dot" data-category="Log-Present"></i>
              @if (currentLog.Any(l => l.WasMilkConsumed == true))
              {
                <i class="bi bi-triangle-fill text-danger event-dot" data-category="Milk-Consumed"></i>
              }

              @if (currentLog.Any(l => l.WasCoffeeConsumed == true))
              {
                <i class="bi bi-circle-fill text-primary event-dot" data-category="Caffe-Consumed"></i>
              }
            }
          </div>
        </label>

        <div class="day-popout">

          <div class="popout-half popout-left p-2 p-md-3 bg-secondary-subtle">
            <label class="close-trigger" for="close-calendar" title="Close"></label>
            <span class="fs-5 fw-bold text-primary">@(index.ToString("00"))</span>

            <div class="event-dots-container">
              @if (currentLog.Any())
              {
                <i class="bi bi-square-fill text-success" style="font-size: 0.7rem;"></i>
                @if (currentLog.Any(l => l.WasMilkConsumed == true))
                {
                  <i class="bi bi-triangle-fill text-danger" style="font-size: 0.7rem;"></i>
                }

                @if (currentLog.Any(l => l.WasCoffeeConsumed == true))
                {
                  <i class="bi bi-circle-fill text-primary" style="font-size: 0.7rem;"></i>
                }
              }
            </div>
          </div>

          <div class="popout-half popout-right bg-body-tertiary">
            <div class="p-2 px-3 border-bottom d-flex justify-content-between align-items-center">
              <span class="fw-bold small text-primary mb-0">History</span>
              <label for="close-calendar" class="text-muted m-0" style="cursor: pointer;"><i
                  class="bi bi-x-lg"></i></label>
            </div>

            <ul class="list-group list-group-flush small overflow-y-auto mb-0" style="flex: 1;">
              @if (!currentLog.Any())
              {
                <li class="list-group-item bg-transparent text-muted fst-italic border-0 px-3 py-2">No logs for today.
                </li>
              }
              else
              {
                @foreach (var log in currentLog)
                {
                  <a class="btn" asp-route="UserHome" asp-route-id="@Model.UserIdentifier" asp-route-date="@log.DateTime!.Value.ToString("s")">
                  <li
                    class="list-group-item bg-transparent px-3 py-2 border-bottom-dashed d-flex align-items-center gap-2">
                    <span class="badge text-bg-primary rounded-pill">@log.DateTime?.TimeOfDay.ToString(@"hh\:mm")</span>
                    @if (log.WasCoffeeConsumed == true)
                    {
                      <i class="bi bi-cup-hot-fill"></i>
                    }
                    @if (log.WasMilkConsumed == true)
                    {
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                           class="bi bi-measuring-cup-fill" viewBox="0 0 16 16">
                        <path
                          d="M14 0a2 2 0 0 1 2 2v5.959a1.041 1.041 0 0 1-2.049.264l-.02-.093-.849-5.096a.041.041 0 0 0-.082.007V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V3.742a2.5 2.5 0 0 0-.732-1.767L.146.854A.5.5 0 0 1 .5 0zM4 13v1h1.5a.5.5 0 0 0 0-1zm0-2v1h3.5a.5.5 0 0 0 0-1zm0-2v1h1.5a.5.5 0 0 0 0-1zm0-2v1h3.5a.5.5 0 0 0 0-1zm0-2v1h1.5a.5.5 0 0 0 0-1zm0-2v1h3.5a.5.5 0 0 0 0-1z"/>
                      </svg>
                    }
                    <span class="fw-semibold">Notes:
                      @if (!log.Notes.IsNullOrEmpty())
                      {
                        @log.Notes![..20]
                      }...
                    </span>
                  </li>
                  </a>
                }
              }
            </ul>
          </div>

        </div>
      </div>
    }

  </div>
</div>