@model LoginViewModel?

@{
    ViewData["Title"] = "Register";
}

<style>
    /* These styles mirror the login page for perfect consistency. 
       Consider moving these shared classes to your site.css! */
    .fit-screen-height {
        min-height: calc(100vh - 160px);
    }

    .login-pane {
        background-color: var(--bs-body-bg); 
    }

    .branding-pane {
        background: linear-gradient(135deg, var(--bs-primary), #6f42c1);
        position: relative;
        overflow: hidden;
    }

    .branding-pane::after {
        content: '';
        position: absolute;
        bottom: -15%;
        left: -10%;
        width: 120%;
        height: 60%;
        background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 60%);
        transform: rotate(-10deg);
        pointer-events: none;
    }

    .touch-input {
        min-height: 4.5rem;
        font-size: 1.25rem;
        border-radius: 0.75rem;
        background-color: var(--bs-secondary-bg);
        border: 1px solid var(--bs-border-color);
    }
    
    .touch-btn {
        min-height: 4.5rem;
        font-size: 1.5rem;
        border-radius: 0.75rem;
    }
</style>

<div class="container-fluid p-0">
    <div class="row g-0 fit-screen-height">
        
        <div class="col-md-6 col-lg-7 d-none d-md-flex flex-column justify-content-center align-items-center branding-pane text-white p-5">
            <h1 class="display-3 fw-bolder mb-3 z-1 text-center">Join Us.</h1>
            <p class="fs-4 fw-light z-1 text-center opacity-75">Create an account to get started.</p>
        </div>

        <div class="col-12 col-md-6 col-lg-5 d-flex align-items-center justify-content-center login-pane p-4 p-md-5">
            <div class="w-100" style="max-width: 450px;">
                
                <div class="mb-5">
                    <h2 class="display-4 fw-bold text-primary mb-2">Register</h2>
                    <p class="text-body-secondary fs-5">Set up your new account below</p>
                </div>

                <form asp-action="RegisterUser" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4 fs-5"></div>
                    
                    <div class="form-floating mb-4">
                        <input asp-for="UserEmailAddress" type="email" class="form-control touch-input" placeholder="name@example.com" autocomplete="email" required />
                        <label asp-for="UserEmailAddress">Email Address</label>
                        <span asp-validation-for="UserEmailAddress" class="text-danger mt-2 d-block"></span>
                    </div>

                    <div class="form-floating mb-5">
                        <input asp-for="UserPasswordHash" type="password" class="form-control touch-input" placeholder="Create a password" autocomplete="new-password" required />
                        <label asp-for="UserPasswordHash">Password</label>
                        <span asp-validation-for="UserPasswordHash" class="text-danger mt-2 d-block"></span>
                    </div>

                    <div class="d-grid gap-3 mt-4">
                        <button type="submit" class="btn btn-primary touch-btn fw-bold">Register</button>
                    </div>
                </form>

                <div class="mt-5 pt-4">
                    <p class="fs-5 text-body-secondary">
                        Already have an account? 
                        <a asp-action="Login" asp-controller="Users" class="text-decoration-none fw-bold ms-1">Log in</a>
                    </p>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}